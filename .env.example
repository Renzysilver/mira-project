# ────────────────────────────────────────────────────────────────────────────
#  Flutter client (.env) — load via `flutter_dotenv`.
#  Copy to `.env` and fill in your own values.
# ────────────────────────────────────────────────────────────────────────────

# Backend HTTP + WebSocket URLs.
# Use 10.0.2.2 for the Android emulator (it maps to the host's localhost).
# Use localhost for iOS sim / web / desktop.
BACKEND_URL=http://10.0.2.2:3000
WS_URL=http://10.0.2.2:3000

# Agora App ID (for voice/video calls). Get one from https://agora.io.
AGORA_APP_ID=your_agora_app_id

# Groq API key — used client-side for TTS (Orpheus) and direct chat fallback.
GROQ_API_KEY=gsk_your_groq_api_key_here
