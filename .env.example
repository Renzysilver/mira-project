# ────────────────────────────────────────────────────────────────────────────
#  Flutter client (.env) — load via `flutter_dotenv`.
#  Copy to `.env` and fill in your own values.
# ────────────────────────────────────────────────────────────────────────────

# Backend HTTP + WebSocket URLs.
# Use 10.0.2.2 for the Android emulator (it maps to the host's localhost).
# Use localhost for iOS sim / web / desktop.
BACKEND_URL=http://10.0.2.2:3000
WS_URL=http://10.0.2.2:3000

# Agora App ID (for voice/video calls). Get one from https://agora.io.
AGORA_APP_ID=your_agora_app_id

# Groq API key — used client-side for TTS (Orpheus) and direct chat fallback.
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── AI provider selection ────────────────────────────────────────────────
# Which AI provider to use for chat completions.
# Options: groq (default), openai, anthropic, gemini
# When you change this, add the corresponding API key below.
AI_PROVIDER=groq
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# ── Voice provider selection ─────────────────────────────────────────────
# Which TTS provider to use for voice calls.
# Options: groq (default), elevenlabs, cartesia, azure
# When you change this, add the corresponding API key below.
VOICE_PROVIDER=groq
# ELEVENLABS_API_KEY=...
# CARTESIA_API_KEY=...
# AZURE_SPEECH_KEY=...
# AZURE_SPEECH_REGION=eastus

# ── Supabase (optional — for the gradual Firebase -> Supabase migration) ──
# Leave these unset to keep using Firebase. To try Supabase, set USE_SUPABASE
# to true and fill in the URL + anon key, then run supabase/schema.sql.
USE_SUPABASE=false
# SUPABASE_URL=https://yourproject.supabase.co
# SUPABASE_ANON_KEY=eyJhbGc...
