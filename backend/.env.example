# ────────────────────────────────────────────────────────────────────────────
#  Node.js backend (.env) — loaded via `dotenv`.
#  Copy to `backend/.env` and fill in your own values.
# ────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins. Leave empty to allow all
# (NOT recommended for production).
CORS_ORIGINS=http://localhost:8080,http://10.0.2.2:8080

# Groq
GROQ_API_KEY=gsk_your_groq_api_key_here

# Agora (for token generation)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Firebase Admin SDK — get these from
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
